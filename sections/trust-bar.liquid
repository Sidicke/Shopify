<link rel="stylesheet" href="{{ 'premium-home.css' | asset_url }}" media="print" onload="this.media='all'">

<div class="trust-bar">
  <div class="bc-container">
    <div class="trust-bar__grid">
      {%- for block in section.blocks -%}
        <div class="trust-bar__item bc-reveal bc-reveal-delay-{{ forloop.index }}">
          <div class="trust-bar__icon">
            {%- if block.settings.icon == 'globe' -%}
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
              </svg>
            {%- elsif block.settings.icon == 'robot' -%}
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="10" rx="2"/><circle cx="12" cy="5" r="2"/><path d="M12 7v4"/><line x1="8" y1="16" x2="8" y2="16"/><line x1="16" y1="16" x2="16" y2="16"/>
              </svg>
            {%- elsif block.settings.icon == 'shield' -%}
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            {%- elsif block.settings.icon == 'trending' -%}
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>
              </svg>
            {%- elsif block.settings.icon == 'zap' -%}
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
              </svg>
            {%- endif -%}
          </div>
          <h3 class="trust-bar__title">{{ block.settings.title }}</h3>
          <p class="trust-bar__text">{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Barre de confiance",
  "tag": "section",
  "class": "section section-trust-bar",
  "settings": [],
  "blocks": [
    {
      "type": "item",
      "name": "Valeur",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icône",
          "options": [
            { "value": "globe", "label": "Globe / International" },
            { "value": "robot", "label": "Robot / IA" },
            { "value": "shield", "label": "Bouclier / Confiance" },
            { "value": "trending", "label": "Tendance / Croissance" },
            { "value": "zap", "label": "Éclair / Rapidité" }
          ],
          "default": "globe"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "default": "Valeur"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Description de la valeur ajoutée."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Barre de confiance",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "icon": "globe",
            "title": "Sourcing International",
            "text": "Nous sourçons les meilleurs produits aux quatre coins du monde pour vous offrir un catalogue exceptionnel."
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "robot",
            "title": "Propulsé par l'IA",
            "text": "Notre écosystème digital utilise l'intelligence artificielle pour optimiser chaque étape de votre expérience d'achat."
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "shield",
            "title": "Transactions Sécurisées",
            "text": "Paiements 100% sécurisés via Shopify. Votre confiance est notre priorité absolue."
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "trending",
            "title": "Commerce Sans Limites",
            "text": "Depuis l'Afrique de l'Ouest vers le monde. Nous repoussons les frontières du commerce traditionnel."
          }
        }
      ]
    }
  ]
}
{% endschema %}
